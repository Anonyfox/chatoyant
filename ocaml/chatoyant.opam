# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Typesafe OCaml and Melange LLM provider SDK"
description:
  "OCaml-first implementation of Chatoyant, with native OCaml libraries and a bundled ESM npm package generated through Melange."
maintainer: ["Anonyfox <max@anonyfox.com>"]
authors: ["Anonyfox <max@anonyfox.com>"]
license: "MIT"
homepage: "https://github.com/Anonyfox/chatoyant"
doc: "https://github.com/Anonyfox/chatoyant"
bug-reports: "https://github.com/Anonyfox/chatoyant/issues"
depends: [
  "ocaml" {>= "5.1"}
  "dune" {>= "3.23"}
  "melange" {>= "6.0.0"}
  "ca-certs"
  "cohttp-eio"
  "domain-name"
  "eio"
  "eio_main" {with-test}
  "http"
  "mirage-crypto-rng"
  "ppxlib" {build}
  "tls"
  "tls-eio"
  "uri"
  "x509"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/Anonyfox/chatoyant.git"
x-maintenance-intent: ["(latest)"]
